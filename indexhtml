<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GREEN Engineering Consulting | GEC 2025</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;600;700;800;900&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{--green:#7DC534;--glow:rgba(125,197,52,0.15);--bg:#0a0a0a;--bg2:#111;--bg3:#161616;--text:#e8e8e8;--muted:#888;--border:rgba(125,197,52,0.2);}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:"Barlow",sans-serif;overflow-x:hidden;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 5vw;height:70px;background:rgba(10,10,10,.92);backdrop-filter:blur(14px);border-bottom:1px solid var(--border);}
.nav-logo{display:flex;align-items:center;gap:12px;text-decoration:none;}
.nav-logo svg{height:36px;}
.nav-brand{font-family:"Barlow Condensed",sans-serif;font-weight:800;font-size:1.45rem;letter-spacing:.08em;color:var(--green);}
.nav-links{display:flex;gap:1.8rem;list-style:none;}
.nav-links a{color:var(--muted);text-decoration:none;font-family:"Barlow Condensed",sans-serif;font-size:.8rem;letter-spacing:.15em;text-transform:uppercase;transition:color .2s;}
.nav-links a:hover{color:var(--green);}
.nav-cta{background:var(--green)!important;color:#000!important;padding:7px 18px;font-weight:700!important;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);}
@media(max-width:900px){.nav-links{display:none;}}

/* HERO */
#hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;gap:0;align-items:stretch;padding-top:70px;position:relative;overflow:hidden;}
.hero-left{display:flex;flex-direction:column;justify-content:center;padding:60px 5vw 60px 5vw;position:relative;z-index:2;}
.hero-right{position:relative;overflow:hidden;background:#050505;}
.hero-grid{position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(125,197,52,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(125,197,52,.03) 1px,transparent 1px);background-size:60px 60px;z-index:0;}

/* BUILDING SVG ILLUSTRATION */
.hero-buildings{position:absolute;inset:0;z-index:1;}
.hero-buildings svg{width:100%;height:100%;}

/* ANIMATED WAVE OVERLAY on right */
.hero-waves-over{position:absolute;inset:0;z-index:2;pointer-events:none;}
.hero-waves-over svg{width:100%;height:100%;}
.wp{fill:none;}
.w0{stroke:rgba(125,197,52,.55);stroke-width:1.5;animation:wv 4s ease-in-out infinite;}
.w1{stroke:rgba(125,197,52,.47);stroke-width:1.4;animation:wv 4.4s ease-in-out infinite .25s;}
.w2{stroke:rgba(125,197,52,.40);stroke-width:1.3;animation:wv 4.8s ease-in-out infinite .5s;}
.w3{stroke:rgba(125,197,52,.33);stroke-width:1.2;animation:wv 5.2s ease-in-out infinite .75s;}
.w4{stroke:rgba(125,197,52,.26);stroke-width:1.2;animation:wv 5.6s ease-in-out infinite 1s;}
.w5{stroke:rgba(125,197,52,.20);stroke-width:1.1;animation:wv 6s ease-in-out infinite 1.25s;}
.w6{stroke:rgba(125,197,52,.14);stroke-width:1.0;animation:wv 6.4s ease-in-out infinite 1.5s;}
.w7{stroke:rgba(125,197,52,.09);stroke-width:.9;animation:wv 6.8s ease-in-out infinite 1.75s;}
.w8{stroke:rgba(125,197,52,.06);stroke-width:.9;animation:wv 7.2s ease-in-out infinite 2s;}
.w9{stroke:rgba(125,197,52,.03);stroke-width:.8;animation:wv 7.6s ease-in-out infinite 2.25s;}
@keyframes wv{0%{transform:translateY(0)}50%{transform:translateY(-20px)}100%{transform:translateY(0)}}

.hero-eyebrow{font-family:"Barlow Condensed",sans-serif;font-size:.78rem;letter-spacing:.3em;text-transform:uppercase;color:var(--green);margin-bottom:1.2rem;display:flex;align-items:center;gap:12px;position:relative;z-index:3;}
.hero-eyebrow::before{content:"";display:block;width:40px;height:2px;background:var(--green);}
h1.hero-title{font-family:"Barlow Condensed",sans-serif;font-weight:900;line-height:.9;font-size:clamp(3.5rem,7vw,8rem);text-transform:uppercase;max-width:700px;position:relative;z-index:3;}
h1.hero-title .ac{color:var(--green);}
.hero-sub{margin-top:1.8rem;max-width:440px;font-size:.98rem;line-height:1.7;color:#aaa;font-weight:300;position:relative;z-index:3;}
.hero-acts{margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;position:relative;z-index:3;}
.btn-p{background:var(--green);color:#000;padding:13px 32px;font-weight:700;font-family:"Barlow Condensed",sans-serif;font-size:.88rem;letter-spacing:.15em;text-transform:uppercase;border:none;cursor:pointer;text-decoration:none;clip-path:polygon(10px 0%,100% 0%,calc(100% - 10px) 100%,0% 100%);transition:background .2s,transform .2s;display:inline-block;}
.btn-p:hover{background:#96e040;transform:translateY(-2px);}
.btn-o{background:transparent;color:var(--green);padding:12px 30px;font-family:"Barlow Condensed",sans-serif;font-size:.88rem;letter-spacing:.15em;text-transform:uppercase;border:1.5px solid var(--green);cursor:pointer;text-decoration:none;transition:background .2s;display:inline-block;}
.btn-o:hover{background:var(--glow);}
.hero-badges{margin-top:3rem;display:flex;gap:2rem;flex-wrap:wrap;position:relative;z-index:3;}
.hb{display:flex;flex-direction:column;gap:4px;}
.hb-num{font-family:"Barlow Condensed",sans-serif;font-weight:800;font-size:2rem;color:var(--green);line-height:1;}
.hb-lbl{font-size:.68rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);}

/* HERO ICON STRIP */
.icon-strip{margin-top:2.5rem;display:flex;gap:.8rem;flex-wrap:wrap;position:relative;z-index:3;}
.istrip-btn{display:flex;flex-direction:column;align-items:center;gap:5px;background:rgba(125,197,52,.05);border:1px solid var(--border);padding:11px 14px;cursor:pointer;transition:all .25s;min-width:82px;text-align:center;outline:none;}
.istrip-btn:hover,.istrip-btn.active{background:rgba(125,197,52,.12);border-color:var(--green);}
.istrip-btn svg{width:24px;height:24px;}
.istrip-lbl{font-family:"Barlow Condensed",sans-serif;font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);line-height:1.2;transition:color .2s;}
.istrip-btn:hover .istrip-lbl,.istrip-btn.active .istrip-lbl{color:var(--green);}

/* SECTIONS */
section{padding:90px 5vw;}
.stag{font-family:"Barlow Condensed",sans-serif;font-size:.72rem;letter-spacing:.3em;text-transform:uppercase;color:var(--green);margin-bottom:1rem;display:flex;align-items:center;gap:10px;}
.stag::before{content:"";display:block;width:28px;height:2px;background:var(--green);}
.stitle{font-family:"Barlow Condensed",sans-serif;font-weight:800;font-size:clamp(2.2rem,4vw,3.6rem);text-transform:uppercase;line-height:.95;margin-bottom:1.5rem;}

/* SERVICIOS */
#servicios{background:var(--bg2);}
.svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);margin-top:3rem;}
.svc-card{background:var(--bg2);padding:1.6rem 1.2rem;display:flex;flex-direction:column;align-items:center;gap:.7rem;text-align:center;cursor:pointer;transition:background .2s;position:relative;overflow:hidden;}
.svc-card::after{content:"";position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--green);transform:scaleX(0);transition:transform .25s;}
.svc-card:hover,.svc-card.active{background:var(--bg3);}
.svc-card:hover::after,.svc-card.active::after{transform:scaleX(1);}
.svc-card svg{width:38px;height:38px;}
.svc-nm{font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:.85rem;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);transition:color .2s;}
.svc-card:hover .svc-nm,.svc-card.active .svc-nm{color:var(--green);}

/* DETAIL PANEL */
.svc-detail{background:var(--bg3);border:1px solid var(--border);border-top:none;display:none;grid-template-columns:1fr 1.3fr;min-height:360px;animation:pIn .3s ease;}
.svc-detail.open{display:grid;}
@keyframes pIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.svc-info{padding:2.5rem;border-right:1px solid var(--border);}
.svc-dtitle{font-family:"Barlow Condensed",sans-serif;font-weight:800;font-size:1.6rem;text-transform:uppercase;color:var(--green);margin-bottom:1.3rem;}
.svc-list{list-style:none;display:flex;flex-direction:column;gap:.55rem;}
.svc-list li{font-size:.88rem;color:#bbb;padding-left:1.2rem;position:relative;line-height:1.5;}
.svc-list li::before{content:"›";position:absolute;left:0;color:var(--green);font-weight:700;}
.svc-vis{position:relative;overflow:hidden;display:flex;align-items:stretch;background:#0a0a0a;}
.svc-vis img{width:100%;height:100%;object-fit:cover;object-position:center;display:block;}
.svc-vis-placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;}
.vis-tag{position:absolute;bottom:.8rem;right:1rem;font-family:"Barlow Condensed",sans-serif;font-size:.6rem;letter-spacing:.2em;color:var(--green);opacity:.55;text-transform:uppercase;background:rgba(0,0,0,.6);padding:3px 8px;}

/* PROPOSITO */
#proposito{background:var(--bg);display:grid;grid-template-columns:1fr 1fr;gap:5vw;align-items:center;}
.p-quote{border-left:3px solid var(--green);padding-left:1.5rem;margin-top:2rem;font-style:italic;color:var(--muted);font-size:.92rem;line-height:1.7;}
.p-quote cite{display:block;margin-top:.8rem;font-style:normal;color:var(--green);font-family:"Barlow Condensed",sans-serif;letter-spacing:.1em;}
.p-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);}
.p-card{background:var(--bg);padding:1.8rem 1.4rem;transition:background .2s;}
.p-card:hover{background:var(--bg3);}
.p-icon{font-size:1.4rem;margin-bottom:.4rem;}
.p-ctitle{font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:.98rem;color:var(--green);margin-bottom:.25rem;}
.p-ctext{font-size:.8rem;color:var(--muted);line-height:1.6;}

/* SECTORES */
#sectores{background:var(--bg2);}
.sec-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--border);margin-top:3rem;}
.sec-card{background:var(--bg2);padding:2.2rem 1rem;display:flex;flex-direction:column;align-items:center;gap:.8rem;text-align:center;transition:background .2s;cursor:default;overflow:hidden;position:relative;}
.sec-card:hover{background:var(--bg3);}
.sec-card-vis{width:100%;height:90px;overflow:hidden;position:relative;margin-bottom:.3rem;}
.sec-card-vis svg{width:100%;height:100%;}
.sec-num{font-family:"Barlow Condensed",sans-serif;font-size:2.4rem;font-weight:900;color:rgba(125,197,52,.1);line-height:1;transition:color .2s;}
.sec-card:hover .sec-num{color:rgba(125,197,52,.35);}
.sec-name{font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:.9rem;letter-spacing:.15em;text-transform:uppercase;}
.sec-bar{width:24px;height:2px;background:var(--green);opacity:.4;}

/* PROCESO */
#proceso{background:var(--bg);}
.proc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);margin-top:3rem;}
.proc-step{background:var(--bg);padding:2.5rem 1.8rem;position:relative;overflow:hidden;transition:background .2s;}
.proc-step:hover{background:var(--bg3);}
.proc-bg{position:absolute;top:.5rem;right:1rem;font-family:"Barlow Condensed",sans-serif;font-size:5.5rem;font-weight:900;color:rgba(125,197,52,.05);line-height:1;}
.proc-title{font-family:"Barlow Condensed",sans-serif;font-weight:800;font-size:1.15rem;text-transform:uppercase;color:var(--green);margin-bottom:.9rem;}
.proc-text{font-size:.85rem;color:var(--muted);line-height:1.7;}

/* CLIENTES */
#clientes{background:var(--bg2);}
.cl-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(148px,1fr));gap:1px;background:var(--border);margin-top:3rem;}
.cl-card{background:var(--bg2);padding:1.6rem 1.2rem;display:flex;align-items:center;justify-content:center;min-height:76px;transition:background .2s;}
.cl-card:hover{background:var(--bg3);}
.cl-name{font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:.82rem;letter-spacing:.08em;text-align:center;color:var(--muted);text-transform:uppercase;transition:color .2s;}
.cl-card:hover .cl-name{color:var(--green);}

/* CONTACTO */
#contacto{background:var(--bg);display:grid;grid-template-columns:1fr 1fr;gap:5vw;align-items:start;}
.ct-info{display:flex;flex-direction:column;gap:1.8rem;}
.ct-item{display:flex;flex-direction:column;gap:.3rem;}
.ct-lbl{font-family:"Barlow Condensed",sans-serif;font-size:.68rem;letter-spacing:.3em;text-transform:uppercase;color:var(--green);}
.ct-val{font-size:1rem;color:var(--text);font-weight:500;}
.ff{display:flex;flex-direction:column;gap:.4rem;margin-bottom:.8rem;}
.ff label{font-size:.68rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);}
.ff input,.ff textarea,.ff select{background:var(--bg2);border:1px solid var(--border);color:var(--text);padding:10px 13px;font-family:"Barlow",sans-serif;font-size:.87rem;outline:none;transition:border-color .2s;resize:none;width:100%;}
.ff input:focus,.ff textarea:focus,.ff select:focus{border-color:var(--green);}
.ff select option{background:var(--bg2);}
.ff textarea{min-height:85px;}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:.9rem;}

/* FOOTER */
footer{background:var(--bg2);padding:2.5rem 5vw;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;}
.fb{font-family:"Barlow Condensed",sans-serif;font-weight:800;font-size:1.15rem;letter-spacing:.1em;color:var(--green);}
.fsub{font-size:.73rem;color:var(--muted);}

/* REVEAL */
.reveal{opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease;}
.reveal.visible{opacity:1;transform:none;}

@media(max-width:1100px){#hero{grid-template-columns:1fr;}.hero-right{display:none;}}
@media(max-width:900px){#proposito,#contacto{grid-template-columns:1fr;}.sec-grid{grid-template-columns:repeat(3,1fr);}.proc-grid,.svc-grid{grid-template-columns:1fr 1fr;}.svc-detail.open{grid-template-columns:1fr;}.frow{grid-template-columns:1fr;}}
</style>
</head>
