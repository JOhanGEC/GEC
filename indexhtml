let cur = -1;

function openSvc(idx) {
  const cards = document.querySelectorAll(".svc-card");
  const detail = document.getElementById("svcDetail");
  const info   = document.getElementById("svcInfo");
  const vis    = document.getElementById("svcVis");

  if (cur === idx) {
    detail.classList.remove("open");
    cards[idx].classList.remove("active");
    cur = -1;
    return;
  }
  cards.forEach(c => c.classList.remove("active"));
  cards[idx].classList.add("active");
  cur = idx;

  const s = SVC[idx];
  info.innerHTML = `<div class="svc-dtitle">${s.title}</div><ul class="svc-list">${s.items.map(i=>`<li>${i}</li>`).join("")}</ul>`;

  if (s.img && IMGS[s.img]) {
    vis.innerHTML = `<img src="${IMGS[s.img]}" alt="${s.title}"><div class="vis-tag">${s.title.toUpperCase()} · GEC</div>`;
  } else if (s.svg) {
    vis.innerHTML = s.svg + `<div class="vis-tag">${s.title.toUpperCase()} · GEC</div>`;
  } else {
    vis.innerHTML = `<div class="svc-vis-placeholder" style="color:rgba(125,197,52,.3);font-size:4rem">◎</div>`;
  }

  detail.classList.remove("open");
  void detail.offsetWidth;
  detail.classList.add("open");
  setTimeout(() => detail.scrollIntoView({behavior:"smooth", block:"nearest"}), 60);
}

function goSvc(idx) {
  document.getElementById("servicios").scrollIntoView({behavior:"smooth"});
  setTimeout(() => openSvc(idx), 600);
}

/* REVEAL */
const obs = new IntersectionObserver(e => e.forEach(en => { if(en.isIntersecting) en.target.classList.add("visible"); }), {threshold:0.08});
document.querySelectorAll(".reveal").forEach(el => obs.observe(el));
document.querySelectorAll("#hero .reveal").forEach(el => {
  const d = parseFloat(el.style.transitionDelay||0)*1000;
  setTimeout(()=>el.classList.add("visible"), d+100);
});
</script>
